# ================================================
# PropOS — Environment Variables
# ================================================
# Copy this file to .env and fill in your values

# --- MT5 Account Credentials ---
# Format: MT5_ACCOUNT_{N}_LOGIN, MT5_ACCOUNT_{N}_PASSWORD, MT5_ACCOUNT_{N}_SERVER
MT5_ACCOUNT_1_LOGIN=12345678
MT5_ACCOUNT_1_PASSWORD=your_password_here
MT5_ACCOUNT_1_SERVER=MetaQuotes-Demo

MT5_ACCOUNT_2_LOGIN=87654321
MT5_ACCOUNT_2_PASSWORD=your_password_here
MT5_ACCOUNT_2_SERVER=MetaQuotes-Demo

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-random-secret

# --- Database ---
DATABASE_URL=sqlite:///./data/propos.db

# --- Environment ---
ENV=development
LOG_LEVEL=INFO
